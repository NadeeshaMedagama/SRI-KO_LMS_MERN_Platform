# SRI-KO LMS Backend - Environment Configuration Template
# Copy this file to config.env and update with your actual values

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration - MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/SriKo?retryWrites=true&w=majority&appName=Cluster0

# Frontend URL Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Security Configuration
SESSION_SECRET=your-session-secret-key-here
JWT_SECRET=your-jwt-secret-key-here

# HTTPS/SSL Configuration (optional)
HTTPS_ENABLE=false
SSL_KEY_PATH=/path/to/ssl/private.key
SSL_CERT_PATH=/path/to/ssl/certificate.crt

# Database Skip Flag (for testing without DB)
SKIP_DB=false

# Other Configuration
LOG_LEVEL=debug

# Email Configuration (for future use)
EMAIL_FROM=noreply@sriko.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

